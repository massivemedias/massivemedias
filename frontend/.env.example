VITE_API_URL=http://localhost:1337/api
VITE_STRIPE_PUBLIC_KEY=your_stripe_public_key_here
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
VITE_GA_ID=G-XXXXXXXXXX
VITE_GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Google Identity Services (One Tap login). Cree un OAuth 2.0 Client ID web sur
# https://console.cloud.google.com/apis/credentials, ajoute massivemedias.com et
# localhost:5173 dans 'Authorized JavaScript origins'. Sans cette variable, le
# prompt One Tap est desactive en silence (le bouton OAuth classique fonctionne toujours).
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
