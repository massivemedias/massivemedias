{
    "kind": "collectionType",
    "collectionName": "calendar_events",
    "info": {
        "singularName": "calendar-event",
        "pluralName": "calendar-events",
        "displayName": "Evenement Calendrier",
        "description": "Evenements du calendrier tatoueur"
    },
    "options": {
        "draftAndPublish": false
    },
    "attributes": {
        "tatoueur": {
            "type": "relation",
            "relation": "manyToOne",
            "target": "api::tatoueur.tatoueur"
        },
        "title": { "type": "string", "required": true },
        "type": {
            "type": "enumeration",
            "enum": ["rendez-vous", "flash-day", "conge", "personnel", "bloque"],
            "default": "rendez-vous"
        },
        "startTime": { "type": "datetime", "required": true },
        "endTime": { "type": "datetime", "required": true },
        "reservation": {
            "type": "relation",
            "relation": "manyToOne",
            "target": "api::reservation.reservation"
        },
        "notes": { "type": "text" },
        "color": { "type": "string", "default": "#FFCC02" }
    }
}
