{
    "kind": "collectionType",
    "collectionName": "reservations",
    "info": {
        "singularName": "reservation",
        "pluralName": "reservations",
        "displayName": "Reservation Tattoo",
        "description": "Reservations de flash pour tatouage"
    },
    "options": {
        "draftAndPublish": false
    },
    "attributes": {
        "tatoueur": {
            "type": "relation",
            "relation": "manyToOne",
            "target": "api::tatoueur.tatoueur"
        },
        "flash": {
            "type": "relation",
            "relation": "manyToOne",
            "target": "api::flash.flash"
        },
        "client": {
            "type": "relation",
            "relation": "manyToOne",
            "target": "api::client.client"
        },
        "clientName": { "type": "string", "required": true },
        "clientEmail": { "type": "email", "required": true },
        "clientPhone": { "type": "string" },
        "placement": { "type": "string" },
        "size": { "type": "string" },
        "messageDuClient": { "type": "text" },
        "referenceImages": {
            "type": "media",
            "multiple": true,
            "allowedTypes": ["images"]
        },
        "status": {
            "type": "enumeration",
            "enum": ["demandee", "confirmee", "planifiee", "realisee", "annulee"],
            "default": "demandee"
        },
        "requestedDate": { "type": "date" },
        "confirmedDate": { "type": "datetime" },
        "budget": { "type": "string" },
        "notes": { "type": "text" },
        "supabaseUserId": { "type": "string" }
    }
}
