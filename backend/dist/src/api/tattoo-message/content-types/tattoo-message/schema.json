{
    "kind": "collectionType",
    "collectionName": "tattoo_messages",
    "info": {
        "singularName": "tattoo-message",
        "pluralName": "tattoo-messages",
        "displayName": "Message Tatoueur",
        "description": "Messages entre clients et tatoueurs"
    },
    "options": {
        "draftAndPublish": false
    },
    "attributes": {
        "tatoueur": {
            "type": "relation",
            "relation": "manyToOne",
            "target": "api::tatoueur.tatoueur"
        },
        "senderName": { "type": "string", "required": true },
        "senderEmail": { "type": "email", "required": true },
        "senderType": {
            "type": "enumeration",
            "enum": ["client", "tatoueur", "admin"],
            "default": "client"
        },
        "content": { "type": "text", "required": true },
        "attachments": {
            "type": "media",
            "multiple": true,
            "allowedTypes": ["images"]
        },
        "conversationId": { "type": "string" },
        "relatedFlash": {
            "type": "relation",
            "relation": "manyToOne",
            "target": "api::flash.flash"
        },
        "relatedReservation": {
            "type": "relation",
            "relation": "manyToOne",
            "target": "api::reservation.reservation"
        },
        "readByRecipient": { "type": "boolean", "default": false },
        "status": {
            "type": "enumeration",
            "enum": ["new", "read", "replied", "archived"],
            "default": "new"
        },
        "supabaseUserId": { "type": "string" }
    }
}
