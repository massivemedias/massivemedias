{
    "kind": "collectionType",
    "collectionName": "projects",
    "info": {
        "singularName": "project",
        "pluralName": "projects",
        "displayName": "Projet (Portfolio)",
        "description": "Etudes de cas du portfolio Massive Medias - generees a partir des commandes livrees via le wizard admin."
    },
    "options": {
        "draftAndPublish": true
    },
    "attributes": {
        "title": {
            "type": "string",
            "required": true
        },
        "slug": {
            "type": "uid",
            "targetField": "title"
        },
        "description": {
            "type": "richtext"
        },
        "clientName": {
            "type": "string"
        },
        "category": {
            "type": "string"
        },
        "images": {
            "type": "media",
            "multiple": true,
            "allowedTypes": ["images"]
        },
        "publishedUrl": {
            "type": "string"
        },
        "tags": {
            "type": "json"
        },
        "sourceOrderRef": {
            "type": "string"
        }
    }
}
