{
    "kind": "collectionType",
    "collectionName": "testimonials",
    "info": {
        "singularName": "testimonial",
        "pluralName": "testimonials",
        "displayName": "Temoignage",
        "description": "Temoignages clients recus apres une commande"
    },
    "options": {
        "draftAndPublish": false
    },
    "pluginOptions": {},
    "attributes": {
        "name": {
            "type": "string",
            "required": true
        },
        "email": {
            "type": "email",
            "required": true
        },
        "roleFr": {
            "type": "string"
        },
        "roleEn": {
            "type": "string"
        },
        "textFr": {
            "type": "text",
            "required": true
        },
        "textEn": {
            "type": "text"
        },
        "rating": {
            "type": "integer",
            "min": 1,
            "max": 5,
            "default": 5
        },
        "approved": {
            "type": "boolean",
            "default": false
        },
        "featured": {
            "type": "boolean",
            "default": false
        },
        "token": {
            "type": "string",
            "unique": true
        },
        "order": {
            "type": "relation",
            "relation": "manyToOne",
            "target": "api::order.order"
        },
        "client": {
            "type": "relation",
            "relation": "manyToOne",
            "target": "api::client.client"
        }
    }
}
