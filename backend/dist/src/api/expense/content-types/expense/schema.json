{
    "kind": "collectionType",
    "collectionName": "expenses",
    "info": {
        "singularName": "expense",
        "pluralName": "expenses",
        "displayName": "Depense",
        "description": "Depenses et comptabilite"
    },
    "options": {
        "draftAndPublish": false
    },
    "attributes": {
        "description": {
            "type": "string",
            "required": true
        },
        "amount": {
            "type": "decimal",
            "required": true
        },
        "category": {
            "type": "enumeration",
            "enum": ["consommables", "materiel", "shipping", "software", "marketing", "equipment", "taxes", "other"],
            "required": true
        },
        "date": {
            "type": "date",
            "required": true
        },
        "vendor": {
            "type": "string"
        },
        "receiptNumber": {
            "type": "string"
        },
        "receipt": {
            "type": "media",
            "multiple": false,
            "allowedTypes": ["images", "files"]
        },
        "taxDeductible": {
            "type": "boolean",
            "default": false
        },
        "tpsAmount": {
            "type": "decimal",
            "default": 0
        },
        "tvqAmount": {
            "type": "decimal",
            "default": 0
        },
        "notes": {
            "type": "text"
        },
        "receiptUrl": {
            "type": "string"
        }
    }
}
