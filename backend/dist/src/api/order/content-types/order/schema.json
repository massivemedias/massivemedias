{
    "kind": "collectionType",
    "collectionName": "orders",
    "info": {
        "singularName": "order",
        "pluralName": "orders",
        "displayName": "Commande",
        "description": "Commandes clients avec paiement Stripe"
    },
    "options": {
        "draftAndPublish": false
    },
    "attributes": {
        "stripePaymentIntentId": {
            "type": "string",
            "unique": true
        },
        "stripeCheckoutSessionId": {
            "type": "string"
        },
        "customerEmail": {
            "type": "email",
            "required": true
        },
        "customerName": {
            "type": "string",
            "required": true
        },
        "companyName": {
            "type": "string"
        },
        "customerPhone": {
            "type": "string"
        },
        "supabaseUserId": {
            "type": "string"
        },
        "items": {
            "type": "json",
            "required": true
        },
        "subtotal": {
            "type": "integer",
            "required": true
        },
        "total": {
            "type": "integer",
            "required": true
        },
        "currency": {
            "type": "string",
            "default": "cad"
        },
        "status": {
            "type": "enumeration",
            "enum": ["draft", "pending", "paid", "processing", "ready", "shipped", "delivered", "cancelled", "refunded"],
            "default": "draft",
            "required": true
        },
        "designReady": {
            "type": "boolean",
            "default": true
        },
        "notes": {
            "type": "text"
        },
        "files": {
            "type": "media",
            "multiple": true,
            "allowedTypes": ["images", "files"]
        },
        "shipping": {
            "type": "integer",
            "default": 0
        },
        "tps": {
            "type": "integer",
            "default": 0
        },
        "tvq": {
            "type": "integer",
            "default": 0
        },
        "shippingAddress": {
            "type": "json"
        },
        "totalWeight": {
            "type": "integer",
            "default": 0
        },
        "trackingNumber": {
            "type": "string"
        },
        "carrier": {
            "type": "enumeration",
            "enum": ["postes-canada", "purolator", "ups", "autre"],
            "default": "postes-canada"
        },
        "invoiceNumber": {
            "type": "string",
            "unique": true
        },
        "promoCode": {
            "type": "string"
        },
        "promoDiscount": {
            "type": "integer",
            "default": 0
        },
        "client": {
            "type": "relation",
            "relation": "manyToOne",
            "target": "api::client.client",
            "inversedBy": "orders"
        },
        "isManual": {
            "type": "boolean",
            "default": false
        },
        "invoice": {
            "type": "relation",
            "relation": "oneToOne",
            "target": "api::invoice.invoice",
            "mappedBy": "order"
        }
    }
}
