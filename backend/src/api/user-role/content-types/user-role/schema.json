      "default": "user",
      "required": true
    },
    "artistSlug": {
      "type": "string"
    },
    "supabaseUserId": {
      "type": "string"
    },
    "displayName": {
      "type": "string"
    },
    "tatoueurSlug": {
      "type": "string"
    },
    "itemRenames": {
      "type": "json"
    },
    "heroImageId": {
      "type": "string"
    }
  }
}
