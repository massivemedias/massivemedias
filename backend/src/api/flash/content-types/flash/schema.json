{
  "kind": "collectionType",
  "collectionName": "flashs",
  "info": {
    "singularName": "flash",
    "pluralName": "flashs",
    "displayName": "Flash Tattoo",
    "description": "Dessins de tatouage (flashs)"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "titleFr": { "type": "string" },
    "titleEn": { "type": "string" },
    "descriptionFr": { "type": "text" },
    "descriptionEn": { "type": "text" },
    "image": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": ["images"]
    },
    "style": { "type": "string" },
    "size": {
      "type": "enumeration",
      "enum": ["petit", "moyen", "grand", "tres-grand"],
      "default": "moyen"
    },
    "bodyPlacement": { "type": "string" },
    "priceTattoo": { "type": "integer" },
    "pricePrint": { "type": "integer" },
    "printAvailable": { "type": "boolean", "default": false },
    "status": {
      "type": "enumeration",
      "enum": ["disponible", "reserve", "tatoue"],
      "default": "disponible"
    },
    "isUnique": { "type": "boolean", "default": true },
    "visible": { "type": "boolean", "default": true },
    "approved": { "type": "boolean", "default": false },
    "sortOrder": { "type": "integer", "default": 0 },
    "tatoueur": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::tatoueur.tatoueur",
      "inversedBy": "flashs"
    }
  }
}
