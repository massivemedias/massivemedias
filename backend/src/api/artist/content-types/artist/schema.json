{
  "kind": "collectionType",
  "collectionName": "artists",
  "info": {
    "singularName": "artist",
    "pluralName": "artists",
    "displayName": "Artiste",
    "description": "Artistes et leurs prints (boutique artistes)"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "slug": { "type": "string", "unique": true, "required": true },
    "name": { "type": "string", "required": true },
    "email": { "type": "email" },
    "taglineFr": { "type": "string" },
    "taglineEn": { "type": "string" },
    "taglineEs": { "type": "string" },
    "bioFr": { "type": "text" },
    "bioEn": { "type": "text" },
    "bioEs": { "type": "text" },
    "demarcheFr": { "type": "json" },
    "demarcheEn": { "type": "json" },
    "demarcheEs": { "type": "json" },
    "avatar": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "heroImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "socials": { "type": "json" },
    "pricing": { "type": "json" },
    "prints": { "type": "json" },
    "stickers": { "type": "json" },
    "printImages": {
      "type": "media",
      "multiple": true,
      "allowedTypes": ["images"]
    },
    "sortOrder": { "type": "integer", "default": 0 },
    "active": { "type": "boolean", "default": true },
    "commissionRate": { "type": "decimal", "default": 0.5 },
    "printCommissionRate": { "type": "decimal", "default": 0.5 },
    "stickerCommissionRate": { "type": "decimal", "default": 0.15 },
    "productionCosts": { "type": "json" }
  }
}
