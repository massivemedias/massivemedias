{
  "kind": "collectionType",
  "collectionName": "withdrawal_requests",
  "info": {
    "singularName": "withdrawal-request",
    "pluralName": "withdrawal-requests",
    "displayName": "Withdrawal Request",
    "description": "Demandes de retrait PayPal des artistes"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "artistSlug": {
      "type": "string",
      "required": true
    },
    "artistName": {
      "type": "string"
    },
    "email": {
      "type": "email",
      "required": true
    },
    "paypalEmail": {
      "type": "email",
      "required": true
    },
    "amount": {
      "type": "decimal",
      "required": true
    },
    "status": {
      "type": "enumeration",
      "enum": ["pending", "processing", "completed", "rejected"],
      "default": "pending"
    },
    "notes": {
      "type": "text"
    },
    "adminNotes": {
      "type": "text"
    },
    "processedAt": {
      "type": "datetime"
    },
    "paypalTransactionId": {
      "type": "string"
    }
  }
}
