{
  "kind": "collectionType",
  "collectionName": "inventory_items",
  "info": {
    "singularName": "inventory-item",
    "pluralName": "inventory-items",
    "displayName": "Inventaire",
    "description": "Gestion d'inventaire — textiles, cadres, accessoires, produits"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "nameFr": {
      "type": "string",
      "required": true
    },
    "nameEn": {
      "type": "string",
      "required": true
    },
    "sku": {
      "type": "string",
      "unique": true
    },
    "category": {
      "type": "enumeration",
      "enum": ["textile", "frame", "accessory", "sticker", "print", "merch", "equipment", "web", "design", "photo", "video", "consulting", "hosting", "other"],
      "required": true
    },
    "variant": {
      "type": "string"
    },
    "quantity": {
      "type": "integer",
      "required": true,
      "default": 0
    },
    "reserved": {
      "type": "integer",
      "default": 0
    },
    "lowStockThreshold": {
      "type": "integer",
      "default": 5
    },
    "costPrice": {
      "type": "decimal"
    },
    "location": {
      "type": "string"
    },
    "product": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::product.product"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "notes": {
      "type": "text"
    },
    "active": {
      "type": "boolean",
      "default": true
    },
    "brand": {
      "type": "string"
    },
    "color": {
      "type": "string"
    },
    "detail": {
      "type": "string"
    },
    "hasZip": {
      "type": "boolean",
      "default": false
    }
  }
}
